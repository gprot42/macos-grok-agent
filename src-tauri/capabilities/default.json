{
  "$schema": "../gen/schemas/capabilities.json",
  "identifier": "default",
  "description": "Cortex Agent — minimal required permissions for core UI (tightened from initial broad grants)",
  "windows": ["main"],
  "permissions": [
    "core:default",

    "dialog:allow-open",
    "dialog:allow-save",

    "fs:default",

    "fs:allow-appdata-read",
    "fs:allow-appdata-write",

    "fs:allow-home-read",
    "fs:allow-home-read-recursive",
    "fs:allow-home-write",

    "fs:allow-download-write",
    "fs:allow-document-write",

    "http:default",
    "http:allow-fetch",

    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-text",

    "shell:allow-open"
  ]
}
