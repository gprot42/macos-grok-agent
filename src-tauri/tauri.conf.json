{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Grok Agent",
  "version": "0.0.1",
  "identifier": "com.cortex.agent",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:4731",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Grok Agent",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "maximized": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: asset:; script-src 'self' 'unsafe-inline' tauri: asset:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: tauri: asset: https:; connect-src 'self' https://api.x.ai https://openrouter.ai https://api.kilocode.ai https://api.anthropic.com https://api.openai.com; font-src 'self' data:; media-src 'self' blob: data:; object-src 'none'; base-uri 'self'",
      "dangerousDisableAssetCspModification": false
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "app"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/icon.png",
      "icons/icon.icns"
    ],
    "resources": [
      "../scripts/*",
      "../README.md"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "frameworks": [],
      "entitlements": "Entitlements.plist"
    }
  },
  "plugins": {}
}
